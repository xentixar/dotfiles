# Sensitive files - DO NOT COMMIT
.ssh/
.gnupg/
.aws/
*.pem
*.key
*_rsa
*_dsa
*_ecdsa
*_ed25519
id_rsa*
*.env
.env*

# Credentials and tokens
credentials
**/credentials
**/config
!config/
*.token
*.secret
passwd

